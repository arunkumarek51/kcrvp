# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/kcrvp
# or MongoDB Atlas: mongodb+srv://user:password@cluster.mongodb.net/kcrvp

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRE=7d

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Blockchain (Polygon Mumbai Testnet)
BLOCKCHAIN_RPC_URL=https://rpc-mumbai.maticvigil.com
BLOCKCHAIN_PRIVATE_KEY=your_wallet_private_key
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# AI Verification (optional - uses mock if not set)
AI_VISION_API_KEY=your_vision_api_key
AI_VISION_ENDPOINT=https://vision.googleapis.com/v1/images:annotate

# Firebase (optional)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY=your_firebase_private_key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
